# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your MongoDB connection string (Local or Atlas)
MONGO_URI=mongodb://localhost:27017/smart-study-planner

# Authentication
# Generate a secure secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# AI Service - Groq API Integration (REQUIRED for Chatbot)
# Groq provides fast and cost-effective LLM inference using Mixtral model
# Get your API key from: https://console.groq.com
# Steps to set up:
# 1. Go to https://console.groq.com
# 2. Sign up or log in
# 3. Click "API Keys" and create a new key
# 4. Copy the key and paste it below
GROQ_API_KEY=gsk_your_groq_api_key_here
